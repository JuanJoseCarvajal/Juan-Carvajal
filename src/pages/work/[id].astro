---
import { works } from '../../data/content';

export function getStaticPaths() {
  return works.map((project) => ({
    params: { id: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project.title} | Work</title>
    <style>
      :root {
        --primary-900: #320a00;
        --primary-800: #641401;
        --primary-700: #951e01;
        --primary-600: #c72802;
        --primary-500: #f93202;
        --primary-400: #fa5b35;
        --primary-300: #fb8467;
        --primary-200: #fdad9a;
        --primary-100: #fed6cc;

        --gray-900: #161616;
        --gray-800: #2d2d2d;
        --gray-700: #434343;
        --gray-600: #5a5a5a;
        --gray-500: #707070;
        --gray-400: #8d8d8d;
        --gray-300: #a9a9a9;
        --gray-200: #c6c6c6;
        --gray-100: #e2e2e2;

        --bg: #f6f7f9;
        --surface: #ffffff;
        --text: var(--gray-900);
        --muted: var(--gray-600);
        --accent: var(--primary-600);
        --border: #d7d7d7;
        --header-bg: rgba(246, 247, 249, 0.92);
      }

      [data-theme='dark'] {
        --bg: #090909;
        --surface: #161616;
        --text: #f4f4f4;
        --muted: #c6c6c6;
        --accent: var(--primary-400);
        --border: #343434;
        --header-bg: rgba(9, 9, 9, 0.9);
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: linear-gradient(160deg, var(--bg), var(--gray-100));
        color: var(--text);
      }
      [data-theme='dark'] body {
        background: linear-gradient(160deg, #090909, #161616);
      }
      header {
        position: sticky;
        top: 0;
        background: var(--header-bg);
        border-bottom: 1px solid var(--border);
        z-index: 20;
      }
      nav {
        max-width: 900px;
        margin: auto;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
      }
      .back-link {
        color: var(--accent);
        text-decoration: none;
      }
      .theme-switcher {
        margin-left: auto;
        color: var(--text);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: .4rem .8rem;
        cursor: pointer;
        font-weight: 600;
      }
      main {
        max-width: 900px;
        margin: auto;
        padding: 2rem 1rem 4rem;
      }
      article {
        border: 1px solid var(--border);
        background: var(--surface);
        border-radius: 1rem;
        padding: 1.5rem;
      }
      h1 {
        margin-top: 0;
        margin-bottom: 1rem;
      }
      section + section {
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
      }
      h2 {
        margin: 0 0 .5rem;
        font-size: 1.1rem;
      }
      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="back-link" href="/#work">← Volver al listado de work</a>
        <button class="theme-switcher" id="theme-switcher" type="button" aria-label="Cambiar tema">
          🌙 Dark
        </button>
      </nav>
    </header>

    <main>
      <article>
        <h1>{project.title}</h1>
        <section>
          <h2>Resumen</h2>
          <p>{project.shortDescription}</p>
        </section>
        <section>
          <h2>Challenge</h2>
          <p>{project.challenge}</p>
        </section>
        <section>
          <h2>Solution</h2>
          <p>{project.solution}</p>
        </section>
        <section>
          <h2>Impact</h2>
          <p>{project.impact}</p>
        </section>
      </article>
    </main>

    <script>
      const switcher = document.getElementById('theme-switcher');

      function setTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        switcher.textContent = theme === 'dark' ? '☀️ Light' : '🌙 Dark';
      }

      const preferredTheme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      setTheme(preferredTheme);

      switcher.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        setTheme(current === 'dark' ? 'light' : 'dark');
      });
    </script>
  </body>
</html>

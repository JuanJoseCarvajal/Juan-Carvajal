---
import { works } from '../../data/content';

export function getStaticPaths() {
  return works.map((project) => ({
    params: { id: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect('/');
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project.title} | Work</title>
    <link rel="stylesheet" href="/theme.css" />
    <script is:inline src="/theme.js"></script>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: var(--surface);
        color: var(--text);
      }
      header {
        position: sticky;
        top: 0;
        background: var(--header-bg);
        border-bottom: 1px solid var(--border);
        z-index: 20;
      }
      nav {
        max-width: 900px;
        margin: auto;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
      }
      .nav-controls {
        margin-left: auto;
        display: flex;
        gap: .6rem;
        align-items: center;
      }
      .back-link {
        color: var(--accent);
        text-decoration: none;
      }
      .lang-select,
      .theme-switcher {
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--surface);
        color: var(--text);
        padding: .4rem .8rem;
        font: inherit;
      }
      main {
        max-width: 900px;
        margin: auto;
        padding: 2rem 1rem 4rem;
      }
      article {
        border: 1px solid var(--border);
        background: var(--surface);
        border-radius: 1rem;
        padding: 1.5rem;
      }
      h1 {
        margin-top: 0;
        margin-bottom: 1rem;
      }
      section + section {
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
      }
      h2 {
        margin: 0 0 .5rem;
        font-size: 1.1rem;
      }
      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a class="back-link" href="/#work" data-i18n="back_to_work">← Volver al listado de proyectos</a>
        <div class="nav-controls">
          <select id="language-select" class="lang-select" aria-label="Selector de idioma" data-i18n-aria-label="lang_aria">
            <option value="es">ES</option>
            <option value="en">EN</option>
          </select>
          <button class="theme-switcher" id="theme-switcher" type="button" aria-label="Cambiar tema">
            🌙 Dark
          </button>
        </div>
      </nav>
    </header>

    <main>
      <article>
        <h1 data-project-field="title">{project.title}</h1>
        <section>
          <h2 data-i18n="summary">Resumen</h2>
          <p data-project-field="shortDescription">{project.shortDescription}</p>
        </section>
        <section>
          <h2 data-i18n="challenge">Reto</h2>
          <p data-project-field="challenge">{project.challenge}</p>
        </section>
        <section>
          <h2 data-i18n="solution">Solución</h2>
          <p data-project-field="solution">{project.solution}</p>
        </section>
        <section>
          <h2 data-i18n="impact">Impacto</h2>
          <p data-project-field="impact">{project.impact}</p>
        </section>
      </article>
    </main>

    <script define:vars={{ project }}>
      window.initializeThemeSwitcher('theme-switcher');

      const languageSelect = document.getElementById('language-select');

      const translations = {
        es: {
          lang_aria: 'Selector de idioma',
          back_to_work: '← Volver al listado de proyectos',
          summary: 'Resumen',
          challenge: 'Reto',
          solution: 'Solución',
          impact: 'Impacto',
          page_suffix: 'Proyecto'
        },
        en: {
          lang_aria: 'Language selector',
          back_to_work: '← Back to work list',
          summary: 'Summary',
          challenge: 'Challenge',
          solution: 'Solution',
          impact: 'Impact',
          page_suffix: 'Project'
        }
      };

      const projectTranslations = {
        'dashboard-analytics': {
          es: {
            title: 'Dashboard de Analytics',
            shortDescription: 'Panel de métricas para equipo comercial en tiempo real.',
            challenge: 'Concentrar múltiples fuentes de datos en una interfaz simple para decisiones semanales.',
            solution: 'Construí widgets modulares, filtros avanzados y vistas comparativas con foco en legibilidad.',
            impact: 'Reducción del 35% en tiempo de análisis manual de reportes.'
          },
          en: {
            title: 'Analytics Dashboard',
            shortDescription: 'Real-time metrics dashboard for the sales team.',
            challenge: 'Consolidate multiple data sources into a simple interface for weekly decision-making.',
            solution: 'Built modular widgets, advanced filters, and comparative views focused on readability.',
            impact: '35% reduction in manual report analysis time.'
          }
        },
        'ecommerce-redesign': {
          es: {
            title: 'Rediseño E-commerce',
            shortDescription: 'Mejora integral del flujo de compra para mobile.',
            challenge: 'El checkout tenía alta fricción y baja conversión en dispositivos de gama media.',
            solution: 'Simplifiqué pasos, optimicé carga de assets y definí un patrón de componentes escalables.',
            impact: 'Incremento del 18% en conversión móvil en 3 meses.'
          },
          en: {
            title: 'E-commerce Redesign',
            shortDescription: 'End-to-end improvement of the mobile purchase flow.',
            challenge: 'Checkout had high friction and low conversion on mid-range devices.',
            solution: 'Simplified steps, optimized asset loading, and defined a scalable component pattern.',
            impact: '18% increase in mobile conversion in 3 months.'
          }
        }
      };

      function applyLanguage(lang) {
        const selectedLanguage = translations[lang] ? lang : 'es';
        const dictionary = translations[selectedLanguage];
        const projectDictionary = projectTranslations[project.slug]?.[selectedLanguage]
          ?? projectTranslations[project.slug]?.es;

        document.documentElement.lang = selectedLanguage;

        document.querySelectorAll('[data-i18n]').forEach((node) => {
          const key = node.dataset.i18n;
          if (dictionary[key]) node.textContent = dictionary[key];
        });

        document.querySelectorAll('[data-i18n-aria-label]').forEach((node) => {
          const key = node.dataset.i18nAriaLabel;
          if (dictionary[key]) node.setAttribute('aria-label', dictionary[key]);
        });

        document.querySelectorAll('[data-project-field]').forEach((node) => {
          const key = node.dataset.projectField;
          const value = projectDictionary?.[key] ?? project[key];
          if (value) node.textContent = value;
        });

        const dynamicTitle = projectDictionary?.title ?? project.title;
        document.title = `${dynamicTitle} | ${dictionary.page_suffix}`;

        localStorage.setItem('language', selectedLanguage);
        if (languageSelect) languageSelect.value = selectedLanguage;
      }

      const savedLanguage = localStorage.getItem('language') || 'es';
      applyLanguage(savedLanguage);
      languageSelect?.addEventListener('change', (event) => {
        applyLanguage(event.target.value);
      });
    </script>
  </body>
</html>
